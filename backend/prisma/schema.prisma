generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  role            String            @default("student")
  createdAt       DateTime          @default(now())
  password        String
  updatedAt       DateTime          @updatedAt
  username        String
  phone           String?
  dob             String?
  city            String?
  program         String?
  semester        String?
  studentId       String?
  address         String?
  about           String?
  profilePic      String?
  branch          String?
  section         String?
  applicationStep Int               @default(0)
  applicationData Json?
  assignments     Assignment[]
  assignment_submissions assignment_submissions[]
  attendance      Attendance[]
  exam            Exam[]
  timetable       Timetable[]
  lesson_plans    lesson_plans[]
  lectures        Lecture[]
  mcq_sets        mcq_sets[]
  notifications   notifications[]
  question_bank   question_bank[]
  question_papers question_papers[]
  appointments    Appointment[]
}

model Program {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  level        String?
  duration     String
  fee_per_year Int
  seats        Int      @default(0)
  intake       String?
  description  String?
  eligibility  String?
  featured     Boolean  @default(false)
  is_open      Boolean  @default(true)
  created_at   DateTime @default(now())
}

model Appointment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicant_id String
  mode         String   @default("video")
  slot         DateTime
  program      String?
  notes        String?
  status       String   @default("requested")
  created_at   DateTime @default(now())
  User         User     @relation(fields: [applicant_id], references: [id], onDelete: Cascade)
}

model Attendance {
  id         String   @id @default(uuid())
  percentage Float
  userId     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Assignment {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                  String
  description            String?
  subject_id             String
  faculty_id             String
  due_date               DateTime
  total_marks            Int                      @default(100)
  status                 String                   @default("active")
  semester               String?                  @db.VarChar(20)
  section                String?                  @db.VarChar(50)
  branch                 String?                  @db.VarChar(100)
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt
  Subject                Subject                  @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  User                   User                     @relation(fields: [faculty_id], references: [id], onDelete: Cascade)
  assignment_submissions assignment_submissions[]
}

model assignment_submissions {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignment_id String     @db.Uuid
  student_id    String
  status        String     @default("pending")
  file_url      String?
  submitted_at  DateTime?
  score         Int?
  feedback      String?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  Assignment    Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  User          User       @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([assignment_id, student_id])
}

model Timetable {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  subject      String
  faculty      String
  room         String
  startTime    String
  duration     Int
  userId       String
  createdAt    DateTime @default(now())
  category     String
  day          String
  lessonplanid String?  @db.Uuid
  source       String?  @default("manual") @db.VarChar(30)
  user         User          @relation(fields: [userId], references: [id])
  lesson_plans lesson_plans? @relation(fields: [lessonplanid], references: [id], onDelete: Cascade)
}

model Chat {
  id        String    @id @default(cuid())
  title     String
  userId    String
  createdAt DateTime  @default(now())
  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id])
}

model Exam {
  id        String    @id @default(uuid())
  subject   String
  code      String
  type      String
  examDate  DateTime  @db.Timestamp(6)
  examTime  String
  venue     String
  duration  String
  status    String?   @default("upcoming")
  userId    String
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Subject {
  id              String            @id
  code            String
  name            String
  faculty         String
  topics          Int?              @default(0)
  progress        Int?              @default(0)
  createdAt       DateTime?         @default(now()) @db.Timestamp(6)
  color           String?           @default("blue")
  userId          String?
  icon            String?
  semester        String?           @db.VarChar(20)
  program         String?           @db.VarChar(100)
  assignments     Assignment[]
  lesson_plans    lesson_plans[]
  lectures        Lecture[]
  mcq_sets        mcq_sets[]
  question_bank   question_bank[]
  question_papers question_papers[]
  units           units[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model question_papers {
  id                String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  title             String    @db.VarChar(255)
  subject_id        String
  faculty_id        String
  exam_type         String?   @db.VarChar(50)
  semester          Int?
  academic_year     String?   @db.VarChar(20)
  total_marks       Int
  duration          String?   @db.VarChar(50)
  difficulty        String?   @db.VarChar(20)
  bloom_level       String?   @db.VarChar(50)
  instructions      String?
  question_count    Int?
  generated_content Json?
  status            String?   @default("draft") @db.VarChar(20)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @db.Timestamp(6)
  ai_prompt         String?
  generation_status String?   @default("pending") @db.VarChar(20)
  pdf_url           String?
  share_token       String?   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_published      Boolean?  @default(false)
  generated_at      DateTime? @db.Timestamp(6)
  selected_units    Int[]
  ai_response       Json?
  User              User      @relation(fields: [faculty_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_faculty")
  Subject           Subject   @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_subject")
}

model mcq_sets {
  id                String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  title             String          @db.VarChar(255)
  subject_id        String
  faculty_id        String
  topic             String?         @db.VarChar(255)
  difficulty        String?         @db.VarChar(20)
  bloom_level       String?         @db.VarChar(50)
  question_count    Int?            @default(0)
  generated_content Json?
  status            String?         @default("draft") @db.VarChar(20)
  created_at        DateTime?       @default(now()) @db.Timestamp(6)
  updated_at        DateTime?       @default(now()) @db.Timestamp(6)
  ai_prompt         String?
  share_token       String?         @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_published      Boolean?        @default(false)
  mcq_questions     mcq_questions[]
  User              User            @relation(fields: [faculty_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_mcq_faculty")
  Subject           Subject         @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_mcq_subject")
}

model mcq_questions {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  mcq_set_id     String
  question       String
  options        Json
  correct_answer String
  explanation    String?
  difficulty     String?   @db.VarChar(20)
  bloom_level    String?   @db.VarChar(50)
  marks          Int?      @default(1)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  mcq_sets       mcq_sets  @relation(fields: [mcq_set_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_mcq_question_set")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model question_bank {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id    String
  faculty_id    String
  unit_id       String?
  question      String
  answer        String?
  marks         Int
  difficulty    String?   @db.VarChar(20)
  bloom_level   String?   @db.VarChar(30)
  question_type String?   @db.VarChar(30)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  User          User      @relation(fields: [faculty_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_question_faculty")
  Subject       Subject   @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_question_subject")
  units         units?    @relation(fields: [unit_id], references: [id], onUpdate: NoAction, map: "fk_question_unit")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model study_materials {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id     String
  faculty_id     String
  title          String
  file_url       String
  extracted_text String?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model units {
  id            String          @id
  title         String          @db.VarChar(255)
  unit_number   Int
  subject_id    String
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  question_bank question_bank[]
  Subject       Subject         @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_subject")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model lesson_plans {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  topic       String
  description String?
  objectives  String?
  lesson_date DateTime  @db.Date
  start_time  DateTime  @db.Time(6)
  duration    String?
  room        String?
  status      String?   @default("draft")
  faculty_id  String
  subject_id  String
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  day         String?   @db.VarChar(20)
  sessions    Int?      @default(1)
  weeks       Int?      @default(1)
  outcomes    Json?
  notes       String?
  User        User        @relation(fields: [faculty_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_faculty")
  Subject     Subject     @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_subject")
  timetable   Timetable[]
}

model Lecture {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id   String
  faculty_id   String
  title        String
  description  String?
  date         DateTime @db.Date
  start_time   String   @db.VarChar(10)
  end_time     String   @db.VarChar(10)
  classroom    String?
  meeting_link String?
  semester     String?  @db.VarChar(20)
  section      String?  @db.VarChar(50)
  branch       String?  @db.VarChar(100)
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamp(6)
  User         User     @relation(fields: [faculty_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Subject      Subject  @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model notifications {
  id           String    @id @default(cuid())
  user_id      String
  title        String
  message      String
  type         String?   @default("lesson_plan") @db.VarChar(40)
  reference_id String?
  is_read      Boolean?  @default(false)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  User         User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_user")

  @@index([user_id, created_at])
}
